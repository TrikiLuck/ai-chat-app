# JWT Secret - используйте случайную строку для production
# Сгенерировать: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production

# Omniroute API настройки
OMNIROUTE_API_KEY=your-omniroute-api-key
OMNIROUTE_ENDPOINT=https://api.omniroute.ai

# PostgreSQL настройки (для Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_chat_app
